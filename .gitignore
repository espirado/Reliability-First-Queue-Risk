# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# LaTeX
*.aux
*.bbl
*.blg
*.log
*.out
*.toc
*.synctex.gz
*.fdb_latexmk
*.fls

# Keep compiled paper PDF out of source control but KEEP figure PDFs
tex/*.pdf
!figures/*.pdf
!**/figures/*.pdf

# Data (large files) — samples and artifacts are tracked, raw bulk is not
*.parquet
*.pkl
*.h5
data/raw/**
data/processed/**
!data/samples/**
!data/samples/*.csv
!data/samples/*.json
# CSV: ignore by default, whitelist artifacts/ and data/samples/ below
*.csv
!artifacts/*.csv
!data/samples/*.csv

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Environment
.env
.env.local

# Model artifacts (large)
*.ckpt
*.pt
*.pth
*.onnx

